@model BloodDonationManagement.Models.BloodRequest

@{
    ViewData["Title"] = "Delete Blood Request";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-xl-8">
            <div class="card shadow-sm border-danger">
                <div class="card-body">
                    <h1 class="h4 text-danger mb-3">Delete Blood Request</h1>
                    <p>Are you sure you want to delete this blood request?</p>

                    <dl class="row mb-4">
                        <dt class="col-sm-4">Patient Name</dt>
                        <dd class="col-sm-8">@Model.PatientName</dd>

                        <dt class="col-sm-4">Blood Group</dt>
                        <dd class="col-sm-8">@Model.BloodGroup</dd>

                        <dt class="col-sm-4">District / Thana</dt>
                        <dd class="col-sm-8">@Model.District?.Name / @Model.Thana?.Name</dd>

                        <dt class="col-sm-4">Contact</dt>
                        <dd class="col-sm-8">@Model.ContactNo</dd>
                    </dl>

                    <form asp-action="DeleteConfirmed" method="post">
                        <input asp-for="BloodRequestId" type="hidden" />
                        <div class="d-flex justify-content-end">
                            <a asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
