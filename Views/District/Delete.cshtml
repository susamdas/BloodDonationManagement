@model BloodDonationManagement.Models.District
@{
    ViewData["Title"] = "Delete District";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    ViewBag.ShowHero = false;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-trash me-2"></i>Delete District</h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Deleting <strong>@Model.Name</strong> may affect donor and request records linked to it.
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Name</dt>
                        <dd class="col-sm-8 fw-semibold">@Model.Name</dd>
                        <dt class="col-sm-4 text-muted">Thanas</dt>
                        <dd class="col-sm-8">@(Model.Thanas?.Count() ?? 0)</dd>
                    </dl>
                </div>
                <div class="card-footer bg-transparent d-flex gap-2">
                    <form asp-action="Delete" method="post" class="d-inline">
                        <input type="hidden" asp-for="DistrictId" />
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash me-1"></i>Yes, Delete
                        </button>
                    </form>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>
