@model BloodDonationManagement.Models.District
@{
    ViewData["Title"] = "District Details";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    ViewBag.ShowHero = false;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-map-marker-alt me-2"></i>@Model.Name</h5>
                </div>
                <div class="card-body p-4">
                    <h6 class="text-muted mb-3">
                        <i class="fas fa-building me-1"></i>
                        Thanas (@(Model.Thanas?.Count() ?? 0))
                    </h6>
                    @if (Model.Thanas?.Any() == true)
                    {
                        <div class="row g-2">
                            @foreach (var thana in Model.Thanas.OrderBy(t => t.Name))
                            {
                                <div class="col-sm-6 col-md-4">
                                    <span class="badge bg-light text-dark border w-100 py-2">@thana.Name</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No thanas added yet.</p>
                    }
                </div>
                <div class="card-footer bg-transparent d-flex gap-2">
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.DistrictId" class="btn btn-outline-warning btn-sm">
                            <i class="fas fa-edit me-1"></i>Edit
                        </a>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-arrow-left me-1"></i>Back
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
