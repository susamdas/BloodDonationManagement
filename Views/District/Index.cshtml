@model IEnumerable<BloodDonationManagement.Models.District>
@{
    ViewData["Title"] = "Districts";
}

<h1 class="mb-4">Districts</h1>
<div class="mb-3">
    <a asp-action="Create" class="btn btn-danger me-2">
        <i class="fas fa-plus-circle me-2"></i>Add District
    </a>
    <a asp-controller="Thana" asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-building me-2"></i>Manage Thanas
    </a>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>District</th>
            <th>Thana Count</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Thanas?.Count()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.DistrictId" class="btn btn-sm btn-outline-primary me-1">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.DistrictId" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.DistrictId" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
