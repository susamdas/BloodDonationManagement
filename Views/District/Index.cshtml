@model IEnumerable<BloodDonationManagement.Models.District>
@{
    ViewData["Title"] = "Districts";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    ViewBag.ShowHero = false;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0"><i class="fas fa-map-marked-alt text-danger me-2"></i>Districts</h4>
            <small class="text-muted">@Model.Count() districts across Bangladesh</small>
        </div>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-danger btn-sm">
                    <i class="fas fa-plus me-1"></i>Add District
                </a>
            }
            <a asp-controller="Thana" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-building me-1"></i>Manage Thanas
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>District</th>
                        <th class="text-center">Thanas</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="text-end">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{int i = 1;}
                    @foreach (var item in Model.OrderBy(d => d.Name))
                    {
                        <tr>
                            <td class="text-muted small">@(i++)</td>
                            <td class="fw-semibold">@item.Name</td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@(item.Thanas?.Count() ?? 0)</span>
                            </td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.DistrictId" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.DistrictId" class="btn btn-sm btn-outline-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.DistrictId" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
