@model BloodDonationManagement.Models.Donor
@{
    ViewData["Title"] = "Delete Donor";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    ViewBag.ShowHero = false;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-danger border-0 shadow-sm">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-trash me-2"></i>Delete Donor</h5>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Are you sure you want to delete this donor? This action cannot be undone.
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Full Name</dt>
                        <dd class="col-sm-8 fw-semibold">@Model.FullName</dd>

                        <dt class="col-sm-4 text-muted">Blood Group</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-danger">@Model.BloodGroup</span>
                        </dd>

                        <dt class="col-sm-4 text-muted">District</dt>
                        <dd class="col-sm-8">@(Model.District?.Name ?? "—")</dd>

                        <dt class="col-sm-4 text-muted">Thana</dt>
                        <dd class="col-sm-8">@(Model.Thana?.Name ?? "—")</dd>

                        <dt class="col-sm-4 text-muted">Contact</dt>
                        <dd class="col-sm-8">@Model.ContactNo</dd>
                    </dl>
                </div>
                <div class="card-footer bg-transparent d-flex gap-2">
                    <form asp-action="DeleteConfirmed" method="post" class="d-inline">
                        <input type="hidden" asp-for="DonorId" />
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash me-1"></i>Yes, Delete
                        </button>
                    </form>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>
