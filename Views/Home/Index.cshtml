@model BloodDonationManagement.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var allGroups = new[] { "A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-" };
    var maxStat = Model.BloodGroupStats.Values.DefaultIfEmpty(1).Max();
}

<div class="container py-4">

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-1">Total Donors</p>
                            <h2 class="fw-bold text-danger mb-0">@Model.TotalDonors</h2>
                            <small class="text-success"><i class="fas fa-check-circle me-1"></i>@Model.ActiveDonors active</small>
                        </div>
                        <div class="bg-danger bg-opacity-10 rounded-3 p-2">
                            <i class="fas fa-users fa-lg text-danger"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-1">Blood Requests</p>
                            <h2 class="fw-bold text-primary mb-0">@Model.TotalRequests</h2>
                            <small class="text-warning"><i class="fas fa-clock me-1"></i>@Model.PendingRequests pending</small>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-3 p-2">
                            <i class="fas fa-hand-holding-medical fa-lg text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-1">Fulfilled</p>
                            <h2 class="fw-bold text-success mb-0">@Model.FulfilledRequests</h2>
                            <small class="text-muted">Lives saved</small>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-2">
                            <i class="fas fa-heart fa-lg text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-1">Locations</p>
                            <h2 class="fw-bold text-info mb-0">@Model.DistrictCount</h2>
                            <small class="text-muted">@Model.ThanaCount thanas</small>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-2">
                            <i class="fas fa-map-marker-alt fa-lg text-info"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Blood Group Availability -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0"><i class="fas fa-tint text-danger me-2"></i>Blood Group Availability</h5>
                    <small class="text-muted">Active donors by blood group</small>
                </div>
                <div class="card-body pt-2">
                    @foreach (var group in allGroups)
                    {
                        var count = Model.BloodGroupStats.GetValueOrDefault(group, 0);
                        var pct = maxStat > 0 ? (int)((double)count / maxStat * 100) : 0;
                        var color = group.Contains("O") ? "danger" : (group.Contains("AB") ? "purple" : (group.Contains("A") ? "primary" : "warning"));
                        var colorClass = group.Contains("O") ? "bg-danger" : (group.Contains("AB") ? "bg-secondary" : (group.Contains("A+") || group.Contains("A-") ? "bg-primary" : "bg-warning"));
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold"><span class="badge bg-danger me-2">@group</span></span>
                                <span class="text-muted small">@count donors</span>
                            </div>
                            <div class="progress" style="height:10px;border-radius:8px">
                                <div class="progress-bar @colorClass" style="width:@pct%;border-radius:8px;transition:width .8s ease"></div>
                            </div>
                        </div>
                    }
                    @if (!Model.BloodGroupStats.Any())
                    {
                        <p class="text-muted text-center py-3"><i class="fas fa-info-circle me-2"></i>No donors registered yet.</p>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Urgent Requests -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0"><i class="fas fa-bell text-warning me-2"></i>Pending Requests</h5>
                        <small class="text-muted">Latest urgent blood needs</small>
                    </div>
                    <a asp-controller="BloodRequest" asp-action="Index" class="btn btn-sm btn-outline-danger">View All</a>
                </div>
                <div class="card-body pt-2 p-0">
                    @if (!Model.RecentRequests.Any())
                    {
                        <p class="text-muted text-center py-4"><i class="fas fa-check-circle text-success me-2"></i>No pending requests.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var req in Model.RecentRequests)
                            {
                                var urgencyBg = req.Urgency == BloodDonationManagement.Models.UrgencyLevel.Critical ? "danger"
                                    : req.Urgency == BloodDonationManagement.Models.UrgencyLevel.Urgent ? "warning" : "success";
                                <li class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <span class="badge bg-danger me-2">@req.BloodGroup</span>
                                            <span class="badge bg-@urgencyBg me-2">@req.Urgency</span>
                                            <strong>@req.PatientName</strong>
                                        </div>
                                        <small class="text-muted">@req.District?.Name</small>
                                    </div>
                                    @if (!string.IsNullOrEmpty(req.HospitalName))
                                    {
                                        <small class="text-muted"><i class="fas fa-hospital me-1"></i>@req.HospitalName</small>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-3 mt-2">
        <div class="col-md-3">
            <a asp-controller="Donor" asp-action="Index" class="card border-0 shadow-sm text-decoration-none h-100 card-hover">
                <div class="card-body text-center py-4">
                    <i class="fas fa-users fa-2x text-danger mb-2"></i>
                    <h6 class="mb-0">Manage Donors</h6>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="BloodRequest" asp-action="Create" class="card border-0 shadow-sm text-decoration-none h-100 card-hover">
                <div class="card-body text-center py-4">
                    <i class="fas fa-plus-circle fa-2x text-primary mb-2"></i>
                    <h6 class="mb-0">Request Blood</h6>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="BloodSearch" asp-action="Index" class="card border-0 shadow-sm text-decoration-none h-100 card-hover">
                <div class="card-body text-center py-4">
                    <i class="fas fa-search fa-2x text-success mb-2"></i>
                    <h6 class="mb-0">Find Donors</h6>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="Map" asp-action="Index" class="card border-0 shadow-sm text-decoration-none h-100 card-hover">
                <div class="card-body text-center py-4">
                    <i class="fas fa-map-marked-alt fa-2x text-info mb-2"></i>
                    <h6 class="mb-0">Live Map</h6>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .card-hover { transition: transform .15s, box-shadow .15s; }
    .card-hover:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.1) !important; }
</style>
