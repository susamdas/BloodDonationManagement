<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BloodConnect BD</title>
    <link rel="icon" type="image/x-icon" href="@Url.Content("~/bloodico.ico")" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root {
            --primary: #dc3545;
            --primary-dark: #b02a37;
        }
        body { background: #f8f9fa; }
        .navbar-brand { font-weight: 700; color: var(--primary) !important; }
        .navbar-nav .nav-link { font-weight: 500; transition: color .2s; }
        .navbar-nav .nav-link:hover,
        .navbar-nav .nav-link.active { color: var(--primary) !important; }
        .hero-section {
            background: linear-gradient(135deg, #dc3545 0%, #fd7e14 100%);
            color: white; padding: 60px 0; margin-bottom: 40px;
        }
        .hero-section h1 { font-size: 2.5rem; font-weight: 700; }
        .btn-custom {
            background: var(--primary); border: none; padding: 10px 26px;
            font-weight: 600; border-radius: 50px; color: white; transition: all .2s;
        }
        .btn-custom:hover { background: var(--primary-dark); color: white; transform: translateY(-1px); }
        .footer { background: #2c3e50; color: white; padding: 40px 0 20px; margin-top: 60px; }
        .footer h5 { color: var(--primary); margin-bottom: 16px; }
        .footer a { color: #bdc3c7; text-decoration: none; }
        .footer a:hover { color: white; }
        .blood-drop { color: var(--primary); animation: pulse 2s infinite; }
        @@keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.1)} }
        /* Urgency badges */
        .badge-critical { background: #dc3545; }
        .badge-urgent   { background: #fd7e14; }
        .badge-normal   { background: #198754; }
        /* Notification bell */
        .notif-bell { position: relative; cursor: pointer; }
        .notif-count {
            position: absolute; top: -6px; right: -8px;
            background: var(--primary); color: white;
            border-radius: 50%; width: 18px; height: 18px;
            font-size: 11px; display: none; align-items: center; justify-content: center;
        }
        /* Toast container */
        #toastArea { position: fixed; bottom: 24px; right: 24px; z-index: 9999; width: 340px; }
        .blood-toast {
            background: white; border-left: 4px solid var(--primary);
            border-radius: 8px; padding: 14px 16px; margin-top: 10px;
            box-shadow: 0 4px 20px rgba(0,0,0,.15); animation: slideIn .3s ease;
        }
        .blood-toast.critical { border-left-color: #dc3545; }
        .blood-toast.urgent   { border-left-color: #fd7e14; }
        @@keyframes slideIn { from{transform:translateX(100%);opacity:0} to{transform:translateX(0);opacity:1} }
        @@keyframes slideOut { from{transform:translateX(0);opacity:1} to{transform:translateX(110%);opacity:0} }
    </style>
    @RenderSection("Head", required: false)
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index","Home")">
                <i class="fas fa-tint blood-drop me-2"></i>BloodConnect BD
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home me-1"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Donor" asp-action="Index">
                            <i class="fas fa-users me-1"></i>Donors
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="BloodRequest" asp-action="Index">
                            <i class="fas fa-hand-holding-medical me-1"></i>Requests
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="BloodSearch" asp-action="Index">
                            <i class="fas fa-search me-1"></i>Search
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Map" asp-action="Index">
                            <i class="fas fa-map-marked-alt me-1"></i>Live Map
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="District" asp-action="Index">
                                <i class="fas fa-location-arrow me-1"></i>Locations
                            </a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav align-items-center">
                    <!-- Notification Bell -->
                    <li class="nav-item me-2">
                        <div class="notif-bell nav-link" id="notifBell" title="Live alerts">
                            <i class="fas fa-bell fa-lg"></i>
                            <span class="notif-count" id="notifCount">0</span>
                        </div>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Page("/Account/Manage/Index", new { area = "Identity" })">
                                <i class="fas fa-user-circle me-1"></i>@(User.Identity?.Name ?? "")
                                @if (User.IsInRole("Admin"))
                                {
                                    <span class="badge ms-1" style="background:#dc3545;font-size:10px;vertical-align:middle;">Admin</span>
                                }
                            </a>
                        </li>
                        <li class="nav-item">
                            <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-custom ms-2">
                                    <i class="fas fa-sign-out-alt me-1"></i>Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Page("/Account/Login", new { area = "Identity" })">
                                <i class="fas fa-sign-in-alt me-1"></i>Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-custom ms-2" href="@Url.Page("/Account/Register", new { area = "Identity" })">
                                <i class="fas fa-user-plus me-1"></i>Register
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        @if (ViewBag.ShowHero != false && ViewData["Title"]?.ToString() == "Dashboard")
        {
            <section class="hero-section text-center">
                <div class="container">
                    <h1><i class="fas fa-tint blood-drop me-3"></i>Save Lives, Donate Blood</h1>
                    <p class="lead mb-4">Connect blood donors with those in need across Bangladesh — instantly.</p>
                    <a asp-controller="BloodSearch" asp-action="Index" class="btn btn-light btn-lg me-3">
                        <i class="fas fa-search me-2"></i>Find Donors
                    </a>
                    <a asp-controller="BloodRequest" asp-action="Create" class="btn btn-outline-light btn-lg me-3">
                        <i class="fas fa-plus me-2"></i>Request Blood
                    </a>
                    <a asp-controller="Map" asp-action="Index" class="btn btn-outline-light btn-lg">
                        <i class="fas fa-map-marked-alt me-2"></i>Live Map
                    </a>
                </div>
            </section>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["InfoMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-info alert-dismissible fade show">
                    <i class="fas fa-info-circle me-2"></i>@TempData["InfoMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }

        @RenderBody()
    </main>

    <!-- Toast Notification Area -->
    <div id="toastArea"></div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h5><i class="fas fa-tint me-2"></i>BloodConnect BD</h5>
                    <p>Connecting blood donors with those in need across Bangladesh. Every drop counts in saving lives.</p>
                </div>
                <div class="col-md-2">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Map" asp-action="Index">Live Map</a></li>
                        <li><a asp-controller="BloodSearch" asp-action="Index">Find Donors</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5>For Donors</h5>
                    <ul class="list-unstyled">
                        <li><a href="@Url.Page("/Account/Register", new { area = "Identity" })">Become a Donor</a></li>
                        <li><a href="@Url.Page("/Account/Manage/Index", new { area = "Identity" })">My Account</a></li>
                        <li><a asp-controller="Donor" asp-action="Create">Register Donor</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5>Emergency</h5>
                    <p><i class="fas fa-phone me-2"></i>01714-496737</p>
                    <p><i class="fas fa-envelope me-2"></i>susam.gbit@gmail.com</p>
                    <p><i class="fas fa-clock me-2"></i>24/7 Available</p>
                </div>
            </div>
            <hr class="mt-3" style="border-color:#ffffff30">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-0">&copy; 2025 BloodConnect BD. All rights reserved. Created by Susam Das</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <a href="@Url.Action("Privacy","Home")" class="me-3">Privacy Policy</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        // Auto-dismiss alerts
        setTimeout(function () {
            document.querySelectorAll('.alert').forEach(function (el) {
                el.style.transition = 'opacity .5s';
                el.style.opacity = '0';
                setTimeout(() => el.remove(), 500);
            });
        }, 5000);

        // Active nav link
        (function () {
            var path = window.location.pathname.toLowerCase();
            document.querySelectorAll('.navbar-nav .nav-link').forEach(function (link) {
                if (link.getAttribute('href') && link.getAttribute('href') !== '/' &&
                    path.includes(link.getAttribute('href').toLowerCase().split('?')[0])) {
                    link.classList.add('active');
                }
            });
        })();

        // SignalR real-time notifications
        var notifCount = 0;
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .withAutomaticReconnect()
            .build();

        connection.on("NewBloodRequest", function (data) {
            notifCount++;
            var countEl = document.getElementById('notifCount');
            countEl.textContent = notifCount;
            countEl.style.display = 'flex';
            showBloodToast(data);
        });

        connection.start().catch(function (err) { console.warn("SignalR:", err); });

        function showBloodToast(data) {
            var urgencyClass = data.urgency === 'Critical' ? 'critical' : (data.urgency === 'Urgent' ? 'urgent' : '');
            var urgencyIcon = data.urgency === 'Critical'
                ? '<i class="fas fa-exclamation-triangle text-danger me-1"></i>'
                : (data.urgency === 'Urgent' ? '<i class="fas fa-exclamation-circle text-warning me-1"></i>' : '');
            var html = '<div class="blood-toast ' + urgencyClass + '">' +
                '<div class="d-flex justify-content-between align-items-start">' +
                '<strong>' + urgencyIcon + data.urgency + ' Blood Request</strong>' +
                '<button onclick="this.closest(\'.blood-toast\').remove()" class="btn-close btn-sm ms-2"></button>' +
                '</div>' +
                '<div class="mt-1"><span class="badge bg-danger me-1">' + data.bloodGroup + '</span>' +
                data.patientName + '</div>' +
                '<small class="text-muted">' + (data.hospital || data.district) + '</small>' +
                '</div>';

            var area = document.getElementById('toastArea');
            area.insertAdjacentHTML('afterbegin', html);

            var toast = area.firstElementChild;
            setTimeout(function () {
                toast.style.animation = 'slideOut .3s ease forwards';
                setTimeout(function () { if (toast.parentNode) toast.remove(); }, 300);
            }, 8000);
        }

        // Reset bell count on click
        document.getElementById('notifBell').addEventListener('click', function () {
            notifCount = 0;
            var el = document.getElementById('notifCount');
            el.textContent = '0';
            el.style.display = 'none';
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
