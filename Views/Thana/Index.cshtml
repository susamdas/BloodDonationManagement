@model IEnumerable<BloodDonationManagement.Models.Thana>
@{
    ViewData["Title"] = "Thanas";
}

<h1 class="mb-4">Thanas</h1>
<div class="mb-3">
    <a asp-action="Create" class="btn btn-danger">
        <i class="fas fa-plus-circle me-2"></i>Add Thana
    </a>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Thana</th>
            <th>District</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.District?.Name</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.ThanaId" class="btn btn-sm btn-outline-primary me-1">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.ThanaId" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.ThanaId" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
