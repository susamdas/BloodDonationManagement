@model IEnumerable<BloodDonationManagement.Models.Thana>
@{
    ViewData["Title"] = "Thanas";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    ViewBag.ShowHero = false;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0"><i class="fas fa-building text-danger me-2"></i>Thanas / Upazilas</h4>
            <small class="text-muted">@Model.Count() thanas across all districts</small>
        </div>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-danger btn-sm">
                    <i class="fas fa-plus me-1"></i>Add Thana
                </a>
            }
            <a asp-controller="District" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-map-marked-alt me-1"></i>Manage Districts
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive" style="max-height:600px;overflow-y:auto;">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light sticky-top">
                    <tr>
                        <th>#</th>
                        <th>Thana</th>
                        <th>District</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="text-end">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{int i = 1;}
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted small">@(i++)</td>
                            <td class="fw-semibold">@item.Name</td>
                            <td><span class="badge bg-light text-dark border">@(item.District?.Name ?? "—")</span></td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@item.ThanaId" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.ThanaId" class="btn btn-sm btn-outline-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.ThanaId" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
